# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ACCESS_TOKEN="your-access-token"

# Funnel public base URL (used to build apply links)
NEXT_PUBLIC_FUNNEL_BASE_URL="https://apply.yourdomain.com"

# Involve.me webhook secret (set the same value in Involve.me as query param)
INVOLVEME_WEBHOOK_SECRET="your-webhook-secret"

# Meta Ads
META_APP_ID="your-meta-app-id"
META_AD_ACCOUNT_ID="act_your-ad-account-id"
META_ACCESS_TOKEN="your-meta-access-token"

# Anthropic Claude
ANTHROPIC_API_KEY="your-anthropic-api-key"

# n8n Webhook Auth
N8N_WEBHOOK_SECRET="your-n8n-webhook-secret"
N8N_BASE_URL="https://n8n.your-domain.com"

# Vapi (Sales-Calls via Direct API)
VAPI_API_KEY="sk_xxxxxxxx"                              # Private Key aus Vapi Dashboard → API Keys
VAPI_ASSISTANT_ID="uuid"                                # Recruiting-Assistant default (altes Recruiting)
VAPI_SALES_ASSISTANT_ID="998f169b-6a78-4eb0-a516-350a64968a8e"  # Sales-Assistant Fallback wenn sales_programs.vapi_assistant_id null
VAPI_SALES_PHONE_NUMBER_ID="uuid"                       # Vapi phoneNumberId der importierten Twilio-Nummer, Fallback wenn sales_programs.vapi_phone_number_id null

# Meta Leadgen Webhook (optional, nur wenn /api/webhook/meta-leadgen genutzt wird)
META_APP_SECRET="your-meta-app-secret"
META_VERIFY_TOKEN="frei-wählbarer-string"
