# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ACCESS_TOKEN="your-access-token"

# Funnel public base URL (used to build apply links)
NEXT_PUBLIC_FUNNEL_BASE_URL="https://apply.yourdomain.com"

# Involve.me webhook secret (set the same value in Involve.me as query param)
INVOLVEME_WEBHOOK_SECRET="your-webhook-secret"

# Meta Ads
META_APP_ID="your-meta-app-id"
META_AD_ACCOUNT_ID="act_your-ad-account-id"
META_ACCESS_TOKEN="your-meta-access-token"

# Anthropic Claude
ANTHROPIC_API_KEY="your-anthropic-api-key"

# n8n Webhook Auth
N8N_WEBHOOK_SECRET="your-n8n-webhook-secret"
N8N_BASE_URL="https://n8n.your-domain.com"

# Vapi (Sales-Calls via Direct API)
# Hinweis: VAPI_API_KEY wird aktuell NICHT in Next.js/Vercel genutzt — der POST /call läuft
# in n8n via httpHeaderAuth-Credential "Vapi API". Nur setzen, wenn später Next.js direkt
# Vapi API callen soll. Format: nur der Key, ohne "Bearer "-Präfix.
# VAPI_API_KEY="7e070089-..."                          # OPTIONAL, nicht nötig für aktuellen Flow
VAPI_ASSISTANT_ID="uuid"                                # Recruiting-Assistant default (altes Recruiting)
VAPI_SALES_ASSISTANT_ID="998f169b-6a78-4eb0-a516-350a64968a8e"  # Sales-Assistant Fallback wenn sales_programs.vapi_assistant_id null
VAPI_SALES_PHONE_NUMBER_ID="uuid"                       # Vapi phoneNumberId der importierten Twilio-Nummer, Fallback wenn sales_programs.vapi_phone_number_id null

# Vapi Webhook Secret für /api/webhook/vapi (Transitional-Mode wenn unset → WARN-Log + accept).
# Set-Anleitung:
#  1. Generiere Random-Wert: `openssl rand -hex 32`
#  2. In Vapi Dashboard → Sales-Assistant → Server URL → Secret-Field eintragen
#  3. Hier + in Vercel-Env als VAPI_WEBHOOK_SECRET setzen
# Sobald gesetzt: Endpoint fail-closed, prüft `X-Vapi-Secret`-Header timing-safe.
# VAPI_WEBHOOK_SECRET="your-random-32-bytes-hex"

# Twilio WhatsApp Sender für /api/sales/offers/send-link (Product-Finder Use-Case).
# Wenn unset: WhatsApp-Channel wird mit WARN-Log übersprungen, SMS läuft trotzdem.
# Wenn gesetzt: WhatsApp-Versand parallel zur SMS. AI sagt dann "SMS und WhatsApp"
# im Pitch (sonst nur "SMS" — via has_whatsapp variableValue im Vapi-Call).
# Sandbox-Test: +14155238886 (Twilio Sandbox-Sender, Lead muss vorher Join-Code senden).
# Production: dein verifizierter WhatsApp-Business-Sender (E.164).
# TWILIO_WHATSAPP_NUMBER="+14155238886"

# Twilio WhatsApp Content-Template-SID (Production-Pflicht außerhalb 24h-Window).
# Wenn gesetzt: sendOfferLink nutzt Template-based-send mit Variables
#   {{1}}=Vorname, {{2}}=Offer-Name, {{3}}=Detail-URL
# Wenn unset: Free-Form (klappt nur in Twilio-Sandbox).
# Template anlegen: Twilio Console → Messaging → Content Builder → Create Template
# Meta-Approval-Antrag stellen, Kategorie "Utility" (24-48h Review).
# Nach Approval Content-SID kopieren (Format: HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx).
# TWILIO_WHATSAPP_CONTENT_SID="HX..."

# Meta Leadgen Webhook (optional, nur wenn /api/webhook/meta-leadgen genutzt wird)
META_APP_SECRET="your-meta-app-secret"
META_VERIFY_TOKEN="frei-wählbarer-string"
